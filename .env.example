# Supabase Edge Function secrets. Keep these server-side only.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Expo public configuration. These values are bundled into the client app.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_REMOTE_SIGNING_ORIGIN=

# Google Sign-In (native). From Google Cloud Console -> Credentials -> OAuth client IDs.
# Web client ID is also the Supabase "Authorized Client IDs" audience value.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
# Reversed iOS client ID (e.g. com.googleusercontent.apps.1234-abcd) -> iOS URL scheme.
EXPO_PUBLIC_GOOGLE_IOS_URL_SCHEME=

# Optional billing keys.
REVENUECAT_APPLE_KEY=
REVENUECAT_GOOGLE_KEY=
